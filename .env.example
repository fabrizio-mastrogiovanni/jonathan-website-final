# ── The Brief (/news) ─────────────────────────────────────────────
# Set these in Vercel → Project → Settings → Environment Variables.
# Until NEWS_FEED_URL is set, production shows the "activándose" state
# (no sample news) and preview/dev show the seed for design review.

# Public URL of the curated feed JSON in Vercel Blob (from the first upload).
# e.g. https://xxxxxxxx.public.blob.vercel-storage.com/news/feed.json
NEWS_FEED_URL=

# Shared secret the n8n workflow sends to /api/revalidate-news to refresh
# the page the moment it publishes. Use a long random string.
REVALIDATE_SECRET=

# NOTE: BLOB_READ_WRITE_TOKEN and ANTHROPIC_API_KEY live in n8n, NOT here.
# See docs/news-pipeline.md for the full setup.
